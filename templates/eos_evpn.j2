!
! Generated by Network Validation Platform
! Fabric: {{ fabric.name }}
! Device: {{ device.hostname }}
! Role: {{ device.role }}
!
no aaa root
!
{% for username, user in services.raw.local_users.items() %}
username {{ username }} privilege {{ user.privilege }} role {{ user.role }}{% if user.secret is defined %} secret {{ user.secret }}{% else %} nopassword{% endif %}
{% endfor %}
!
hostname {{ device.hostname }}
!
spanning-tree mode {{ services.raw.eos.spanning_tree_mode }}
!
service routing protocols model {{ services.raw.eos.service_routing_protocols_model }}
!
management api http-commands
   no shutdown
!
{% for vlan_id, vlan in vlans.items() %}
vlan {{ vlan_id }}
   name {{ vlan.name }}
!
{% endfor %}
{% for vrf_name, vrf in vrfs.items() %}
vrf instance {{ vrf_name }}
!
{% endfor %}
interface Loopback0
   description Router ID
   ip address {{ device.loopback0 }}
!
{% if device.loopback1 %}
interface Loopback1
   description VTEP source
   ip address {{ device.loopback1 }}
!
{% endif %}
{% for interface_name, interface in device.interfaces.items() %}
interface {{ interface_name }}
   description {{ interface.description }}
{% if interface.type == "routed" %}
   no switchport
   ip address {{ interface.ip_address }}
{% elif interface.type == "access" %}
   switchport access vlan {{ interface.vlan }}
{% endif %}
   no shutdown
!
{% endfor %}
{% for vlan_id, vlan in vlans.items() %}
interface Vlan{{ vlan_id }}
   description {{ vlan.name }} gateway
   vrf {{ vlan.vrf }}
   ip address virtual {{ vlan.gateway }}
!
{% endfor %}
{% if device.role == "leaf" %}
interface Vxlan1
   vxlan source-interface {{ overlay.vtep_source_interface }}
{% for vlan_id, vlan in vlans.items() %}
   vxlan vlan {{ vlan_id }} vni {{ vlan.vni }}
{% endfor %}
{% for vrf_name, vrf in vrfs.items() %}
   vxlan vrf {{ vrf_name }} vni {{ vrf.vni }}
{% endfor %}
!
ip virtual-router mac-address 00:1c:73:00:00:99
!
{% endif %}
ip routing
{% for vrf_name in vrfs %}
ip routing vrf {{ vrf_name }}
{% endfor %}
!
router bgp {{ device.asn }}
   router-id {{ router_id }}
   maximum-paths {{ underlay.maximum_paths }}
{% for neighbor in bgp_neighbors %}
   neighbor {{ neighbor.ip }} remote-as {{ neighbor.remote_as }}
   neighbor {{ neighbor.ip }} description {{ neighbor.name }} underlay
{% endfor %}
{% for network in advertised_networks %}
   network {{ network }}
{% endfor %}
{% if device.role == "leaf" %}
{% for vlan_id, vlan in vlans.items() %}
   !
   vlan {{ vlan_id }}
      rd auto
      route-target both {{ vlan.vni }}:{{ vlan.vni }}
      redistribute learned
{% endfor %}
{% for vrf_name, vrf in vrfs.items() %}
   !
   vrf {{ vrf_name }}
      rd auto
      route-target import evpn {{ vrf.vni }}:{{ vrf.vni }}
      route-target export evpn {{ vrf.vni }}:{{ vrf.vni }}
      redistribute connected
{% endfor %}
{% endif %}
!
end
